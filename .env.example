# SelfClaude environment file. Copy to `.env` and fill what you need.
# Everything below is OPTIONAL — SelfClaude runs fine with no .env at all.
# Telegram is the only integration that needs configuration.

# ─── Telegram (optional) ─────────────────────────────────────────────
# Forwards unanswered questions / approvals to your Telegram chat after
# 15s. Get a token from @BotFather, then run `selfclaude link-telegram`
# to auto-discover and persist the CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Anthropic API (NOT needed here) ─────────────────────────────────
# SelfClaude does NOT read ANTHROPIC_API_KEY. The `claude` CLI
# (Anthropic's Claude Code) handles auth itself — install from
# https://docs.claude.com/en/docs/claude-code/quickstart and run
# `claude` once to sign in.
