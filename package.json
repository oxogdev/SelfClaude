{
  "name": "selfclaude",
  "version": "0.0.1",
  "description": "Two-agent Claude Code orchestration TUI",
  "private": true,
  "type": "module",
  "bin": {
    "selfclaude": "./bin/selfclaude.mjs"
  },
  "scripts": {
    "dev": "tsx bin/selfclaude.ts",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "lint": "biome check src bin tests",
    "format": "biome format --write src bin tests",
    "test": "tsx --test tests/*.test.ts",
    "test:integration": "tsx --test tests/integration/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "grammy": "^1.30.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
