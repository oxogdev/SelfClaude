{
  "name": "selfclaude-monorepo",
  "version": "0.0.1",
  "description": "Two-Claude orchestration: monorepo root",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @selfclaude/cli dev",
