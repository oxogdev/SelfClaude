{
  "name": "selfclaude-monorepo",
  "version": "0.0.1",
  "description": "Multi-agent orchestration for Claude Code — supervisor + specialists with you in the loop",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "badursun <badursun@gmail.com>",
  "homepage": "https://github.com/badursun/SelfClaude",
  "repository": {
    "type": "git",
    "url": "https://github.com/badursun/SelfClaude.git"
  },
  "bugs": {
    "url": "https://github.com/badursun/SelfClaude/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai-agents",
    "multi-agent",
    "orchestration",
    "developer-tools"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --filter @selfclaude/cli dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter @selfclaude/core test",
    "test:integration": "pnpm --filter @selfclaude/core test:integration",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check packages",
    "format": "biome format --write packages"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "concurrently": "^9.1.2"
  }
}
